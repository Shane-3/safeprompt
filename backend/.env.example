# Database
DATABASE_URL=postgresql://safeprompt:safeprompt_dev@localhost:5432/safeprompt

# JWT
JWT_SECRET=change-this-to-a-strong-secret
JWT_EXPIRATION=24h

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-1.5-flash,gemini-2.0-flash-lite

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
